<Page x:Class="casino.blackjack"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:casino"
      mc:Ignorable="d"
      d:DesignHeight="720" d:DesignWidth="1280"
      Title="blackjack">

    <Page.Resources>
        <ControlTemplate x:Key="ChipBtn" TargetType="{x:Type Button}">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="Transparent"
                    BorderThickness="0">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </ControlTemplate>

        <ControlTemplate x:Key="BJ_gombok" TargetType="{x:Type Button}">
            <Border x:Name="border"
                    Background="{TemplateBinding Background}"
                    BorderBrush="#4A3A1A"
                    BorderThickness="1.5"
                    CornerRadius="3">
                <Border x:Name="innerGlow"
                        Background="Transparent"
                        CornerRadius="2"
                        Margin="1">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="border" Property="BorderBrush" Value="#C9A84C"/>
                    <Setter TargetName="border" Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#C9A84C" BlurRadius="12" ShadowDepth="0" Opacity="0.6"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="border" Property="Opacity" Value="0.75"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="border" Property="Opacity" Value="0.3"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="BetBtn" TargetType="{x:Type Button}">
            <Border x:Name="border"
                    Background="{TemplateBinding Background}"
                    BorderBrush="#4A3A1A"
                    BorderThickness="1.5"
                    CornerRadius="90">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="border" Property="BorderBrush" Value="#C9A84C"/>
                    <Setter TargetName="border" Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#C9A84C" BlurRadius="14" ShadowDepth="0" Opacity="0.7"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="border" Property="Opacity" Value="0.75"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="border" Property="Opacity" Value="0.3"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Page.Resources>

    <Page.Background>
        <SolidColorBrush Color="#0A0A0A"/>
    </Page.Background>

    <Viewbox Stretch="Uniform">
        <Grid Width="1280" Height="720">
            <Grid.Background>
                <ImageBrush ImageSource="bj_hatter.png" Stretch="UniformToFill" Opacity="0.55"/>
            </Grid.Background>
            <Grid.RowDefinitions>
                <RowDefinition Height="90*"/>
                <RowDefinition Height="108*"/>
                <RowDefinition Height="101*"/>
                <RowDefinition Height="61*"/>
            </Grid.RowDefinitions>

            <!-- Overlay gradient -->
            <Rectangle Grid.Row="0" Grid.RowSpan="4">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                        <GradientStop Color="#CC000000" Offset="0"/>
                        <GradientStop Color="#55000000" Offset="0.5"/>
                        <GradientStop Color="#EE000000" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Arany vonal felul -->
            <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Bottom" Margin="60,0,60,0" Opacity="0.5">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#C9A84C" Offset="0.3"/>
                        <GradientStop Color="#F0D080" Offset="0.5"/>
                        <GradientStop Color="#C9A84C" Offset="0.7"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Arany vonal alul -->
            <Rectangle Grid.Row="3" Height="1" VerticalAlignment="Top" Margin="60,0,60,0" Opacity="0.4">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#C9A84C" Offset="0.3"/>
                        <GradientStop Color="#F0D080" Offset="0.5"/>
                        <GradientStop Color="#C9A84C" Offset="0.7"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- ROW 0: Felso sor -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Button x:Name="vissza"
                        Grid.Column="0"
                        Template="{DynamicResource BJ_gombok}"
                        Height="38" Width="130"
                        VerticalAlignment="Top" HorizontalAlignment="Left"
                        Margin="24,20,0,0"
                        FontSize="13"
                        FontFamily="Segoe UI Light"
                        FontWeight="Light"
                        Click="vissza_Click"
                        Foreground="#C9A84C"
                        Background="#1A1610"
                        Content="&lt; VISSZA"/>

                <Border Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,16,0,0"
                        Background="#1A1610"
                        BorderBrush="#4A3A1A"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="16,7">
                    <local:ido Background="#1A1610"/>
                </Border>

                <Border Grid.Column="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,16,24,0"
                        Background="#1A1610"
                        BorderBrush="#4A3A1A"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="16,8">
                    <TextBlock x:Name="egyenlegTB"
                               Foreground="#C9A84C"
                               FontSize="16"
                               FontFamily="Palatino Linotype">
                        <Run Text="EGYENLEG  " Foreground="#7A6A3A" FontSize="11" FontFamily="Segoe UI Light"/>
                        <Run x:Name="egyenlegertek" Text="50 000 Ft" Foreground="#F0D080"/>
                    </TextBlock>
                </Border>
            </Grid>

            <!-- ROW 1: Oszto -->
            <Canvas x:Name="OsztoCanva" Grid.Row="1">
                <ItemsControl x:Name="OsztoLapjai" Canvas.Left="580" Canvas.Top="25">
                    <StackPanel Orientation="Horizontal" x:Name="OsztoKartyaSP"/>
                </ItemsControl>
            </Canvas>

            <Label x:Name="OsztoKartyakOsszge"
                   Grid.Row="1"
                   Content=""
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   FontSize="16"
                   FontFamily="Palatino Linotype"
                   Foreground="#8A7A4A"/>

            <!-- ROW 2: Jatekos -->
            <Canvas x:Name="JatekosCanva" Grid.Row="2">
                <Image x:Name="DeckImage"
                       Source="/jatekok/blackjack/back.png"
                       Canvas.Left="1120" Canvas.Top="-10"
                       Width="auto" Height="160"
                       Opacity="0.9"/>

                <ItemsControl x:Name="JatekosKartyai" Canvas.Left="580" Canvas.Top="20">
                    <StackPanel Orientation="Horizontal" x:Name="JatekosKartyaSP"/>
                </ItemsControl>

                <Button Template="{DynamicResource ChipBtn}"
                        Canvas.Top="80" Canvas.Left="410"
                        Visibility="Hidden"
                        Foreground="White" FontSize="18"
                        x:Name="chip" Width="120" Height="120" Margin="20"
                        ToolTip="chip" ToolTipService.Placement="Top">
                    <Button.Background>
                        <ImageBrush ImageSource="/jatekok/blackjack/chip.png"/>
                    </Button.Background>
                </Button>
            </Canvas>

            <Label x:Name="JatekosKartyakOsszge"
                   Grid.Row="2"
                   Content=""
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,4,0,0"
                   FontSize="16"
                   FontFamily="Palatino Linotype"
                   Foreground="#C9A84C"/>

            <Label x:Name="eredmenyLabel"
                   Grid.Row="2"
                   Content=""
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="36"
                   FontWeight="Bold"
                   FontFamily="Palatino Linotype"
                   Foreground="#F0D080"
                   Padding="28,12"/>

            <!-- HIT/STAND/DOUBLE -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,8">
                <StackPanel x:Name="kezelo"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Hidden">

                    <Button Template="{DynamicResource BJ_gombok}"
                            x:Name="hit" Width="70" Height="50" Margin="8"
                            ToolTip="Huzas" ToolTipService.Placement="Top"
                            Click="hit_Click"
                            Background="#1A1610"
                            Foreground="#C9A84C">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="+" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#C9A84C"/>
                            <TextBlock Text="HIT" FontSize="11" FontFamily="Segoe UI Light" HorizontalAlignment="Center" Foreground="#C9A84C"/>
                        </StackPanel>
                    </Button>

                    <Button Template="{DynamicResource BJ_gombok}"
                            x:Name="stand" Width="70" Height="50" Margin="8"
                            ToolTip="Megall" ToolTipService.Placement="Top"
                            Click="stand_Click"
                            Background="#1A1610"
                            Foreground="#C9A84C">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="||" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#C9A84C"/>
                            <TextBlock Text="STAND" FontSize="11" FontFamily="Segoe UI Light" HorizontalAlignment="Center" Foreground="#C9A84C"/>
                        </StackPanel>
                    </Button>

                    <Button Template="{DynamicResource BJ_gombok}"
                            x:Name="double" Width="70" Height="50" Margin="8"
                            ToolTip="Duplazas" ToolTipService.Placement="Top"
                            Background="#1A1610"
                            Foreground="#C9A84C">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="x2" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#F0D080"/>
                            <TextBlock Text="DOUBLE" FontSize="11" FontFamily="Segoe UI Light" HorizontalAlignment="Center" Foreground="#C9A84C"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </StackPanel>

            <!-- Rebet -->
            <Button Template="{DynamicResource BetBtn}"
                    Grid.Row="2"
                    Visibility="Hidden"
                    Foreground="#C9A84C"
                    x:Name="rebet"
                    Width="120" Height="120"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    ToolTip="rebet" ToolTipService.Placement="Top"
                    Click="rebet_Click"
                    Background="#1A1610">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="&#x21BA;" FontSize="32" HorizontalAlignment="Center" Foreground="#C9A84C"/>
                    <TextBlock Text="REBET" FontSize="13" FontFamily="Segoe UI Light" HorizontalAlignment="Center" Foreground="#C9A84C"/>
                </StackPanel>
            </Button>

            <!-- ROW 3: Bet panel -->
            <Border Grid.Row="3"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Background="#0D0B08"
                    BorderBrush="#3A2A0A"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="8,6">
                <StackPanel x:Name="tetkezelo" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">

                    <Button Template="{DynamicResource BJ_gombok}"
                            x:Name="reset" Width="54" Height="44" Margin="6,0"
                            ToolTip="Reset" ToolTipService.Placement="Top"
                            Click="reset_Click"
                            Background="#1A1610"
                            Foreground="#C9A84C"
                            Content="&#x21BA;"/>

                    <Button Template="{DynamicResource BetBtn}"
                            x:Name="min" Width="44" Height="44" Margin="4,0"
                            ToolTip="100" ToolTipService.Placement="Top"
                            Click="min_Click"
                            Background="#1A1610"
                            Foreground="#C9A84C"
                            Content="MIN"/>

                    <Button Template="{DynamicResource BetBtn}"
                            x:Name="minusx" Width="44" Height="44" Margin="4,0"
                            ToolTip="-500" ToolTipService.Placement="Top"
                            Click="minusx_Click"
                            Background="#1A1610"
                            Foreground="#C9A84C"
                            Content="&lt;&lt;"/>

                    <Button Template="{DynamicResource BetBtn}"
                            x:Name="minus" Width="44" Height="44" Margin="4,0"
                            ToolTip="-100" ToolTipService.Placement="Top"
                            Click="minus_Click"
                            Background="#1A1610"
                            Foreground="#C9A84C"
                            Content="&lt;"/>

                    <Border Background="#0A0806"
                            BorderBrush="#4A3A1A"
                            BorderThickness="1"
                            CornerRadius="3"
                            Margin="8,0"
                            Padding="20,0"
                            MinWidth="110">
                        <Label x:Name="bet"
                               Content="0 Ft"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#F0D080"
                               FontSize="17"
                               FontFamily="Palatino Linotype"
                               Background="Transparent"
                               Padding="0,8"/>
                    </Border>

                    <Button Template="{DynamicResource BetBtn}"
                            x:Name="plus" Width="44" Height="44" Margin="4,0"
                            ToolTip="+100" ToolTipService.Placement="Top"
                            Click="plus_Click"
                            Background="#1A1610"
                            Foreground="#C9A84C"
                            Content="&gt;"/>

                    <Button Template="{DynamicResource BetBtn}"
                            x:Name="plusx" Width="44" Height="44" Margin="4,0"
                            ToolTip="+500" ToolTipService.Placement="Top"
                            Click="plusx_Click"
                            Background="#1A1610"
                            Foreground="#C9A84C"
                            Content="&gt;&gt;"/>

                    <Button Template="{DynamicResource BetBtn}"
                            x:Name="max" Width="44" Height="44" Margin="4,0"
                            ToolTip="500 000" ToolTipService.Placement="Top"
                            Click="max_Click"
                            Background="#1A1610"
                            Foreground="#C9A84C"
                            Content="MAX"/>

                    <Button Template="{DynamicResource BJ_gombok}"
                            x:Name="deal" Width="90" Height="44" Margin="10,0,6,0"
                            ToolTip="Kioszt" ToolTipService.Placement="Top"
                            Click="deal_Click"
                            Background="#2A1E08"
                            Foreground="#F0D080"
                            Content="DEAL"/>

                </StackPanel>
            </Border>

        </Grid>
    </Viewbox>
</Page>
