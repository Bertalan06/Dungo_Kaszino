<Page x:Class="casino.slot"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:casino"
      mc:Ignorable="d" 
      d:DesignHeight="720" d:DesignWidth="1100"
      Title="slot">

    <Page.Resources>
        <!-- Casino gomb -->
        <Style x:Key="KasinoGomb" TargetType="Button">
            <Setter Property="Background" Value="#1a1a1a"/>
            <Setter Property="Foreground" Value="#FFD700"/>
            <Setter Property="BorderBrush" Value="#FFD700"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Brd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Brd" Property="Background" Value="#2a2a00"/>
                                <Setter TargetName="Brd" Property="BorderBrush" Value="#FFEE00"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Brd" Property="Background" Value="#FFD700"/>
                                <Setter Property="Foreground" Value="#000"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Brd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Vissza gomb -->
        <Style x:Key="VisszaGomb" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Brd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Brd" Property="BorderBrush" Value="#666"/>
                                <Setter Property="Foreground" Value="#aaa"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Pörgetés gomb -->
        <Style x:Key="PörgetésGomb" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="110"/>
            <Setter Property="Height" Value="110"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="Gyűrű" Width="110" Height="110">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#FFD700" Offset="0"/>
                                        <GradientStop Color="#B8860B" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#FFD700" BlurRadius="22" ShadowDepth="0" Opacity="0.7"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <Ellipse Width="94" Height="94">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#2a2a00" Offset="0"/>
                                        <GradientStop Color="#111100" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="▶" FontSize="30" Foreground="#FFD700" HorizontalAlignment="Center"/>
                                <TextBlock Text="PÖRGETÉS" FontSize="8" Foreground="#FFD700"
                                           FontWeight="Bold" FontFamily="Consolas" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Gyűrű" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Gyűrű" Property="Width" Value="104"/>
                                <Setter TargetName="Gyűrű" Property="Height" Value="104"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Gyűrű" Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle gomb -->
        <Style x:Key="ToggleGomb" TargetType="ToggleButton">
            <Setter Property="Background" Value="#1a1a1a"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Brd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Brd" Property="Background" Value="#1a1500"/>
                                <Setter TargetName="Brd" Property="BorderBrush" Value="#FFD700"/>
                                <Setter Property="Foreground" Value="#FFD700"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Brd" Property="BorderBrush" Value="#666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <!-- Fő háttér -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#080808" Offset="0"/>
                <GradientStop Color="#0f0f08" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <!-- fejléc -->
            <RowDefinition Height="*"/>
            <!-- tartalom -->
            <RowDefinition Height="85"/>
            <!-- vezérlők -->
        </Grid.RowDefinitions>

        <!-- fejléc -->
        <Border Grid.Row="0" Background="#0a0a0a" BorderBrush="#1a1a1a" BorderThickness="0,0,0,1">
            <Grid Margin="14,0">
                <!-- Vissza gomb -->
                <Button Style="{StaticResource VisszaGomb}"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Content="◀  Vissza" Click="Button_Click"/>

                <!-- Egyenleg -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="100,0,0,0">
                    <TextBlock Text="EGYENLEG" Foreground="#444" FontFamily="Consolas" FontSize="10" VerticalAlignment="Center"/>
                    <TextBlock x:Name="tbEgyenleg" Text="0 Ft"
                               Foreground="#FFD700" FontFamily="Consolas" FontSize="20"
                               FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FFD700" BlurRadius="12" ShadowDepth="0" Opacity="0.7"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>

                <!-- Cím -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock HorizontalAlignment="Center" FontFamily="Consolas" FontWeight="Bold">
                        <Run Text="Slot Machine" FontSize="17" Foreground="#FFD700"/>
                    </TextBlock>
                </StackPanel>

                <!-- Utolsó nyeremény -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="UTOLSÓ:" Foreground="#444" FontFamily="Consolas" FontSize="10" VerticalAlignment="Center"/>
                    <TextBlock x:Name="tbUtolso" Text="0 Ft"
                               Foreground="#FFD700" FontFamily="Consolas" FontSize="16"
                               FontWeight="Bold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- TARTALOM -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="170"/>
            </Grid.ColumnDefinitions>

            <!-- BAL oldal -->
            <Border Grid.Column="0" Background="#080808" Margin="12,12,4,12" CornerRadius="12"
                    BorderBrush="#1a1a1a" BorderThickness="1">
                <StackPanel Margin="14,16,14,10">
                    <TextBlock Text="KIFIZETÉSI TÁBLÁZAT" Foreground="#FFD700" FontFamily="Consolas"
                               FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,14"/>

                    <!-- Kifizetés táblázata -->
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="7"   Width="30" FontSize="20" FontWeight="Bold" Foreground="#FF3333" VerticalAlignment="Center"/>
                        <TextBlock Text="3x"  Width="22" FontSize="10" Foreground="#666" VerticalAlignment="Center"/>
                        <TextBlock Text="300" FontSize="13" Foreground="#FFD700" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="⭐" Width="30" FontSize="18" VerticalAlignment="Center" Foreground="white"/>
                        <TextBlock Text="3x" Width="22" FontSize="10" Foreground="#666" VerticalAlignment="Center"/>
                        <TextBlock Text="200" FontSize="13" Foreground="#FFD700" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="🔔" Width="30" FontSize="18" VerticalAlignment="Center" Foreground="white"/>
                        <TextBlock Text="3x" Width="22" FontSize="10" Foreground="#666" VerticalAlignment="Center"/>
                        <TextBlock Text="100" FontSize="13" Foreground="#FFD700" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="🍉" Width="30" FontSize="18" VerticalAlignment="Center" Foreground="white"/>
                        <TextBlock Text="3x" Width="22" FontSize="10" Foreground="#666" VerticalAlignment="Center"/>
                        <TextBlock Text="80"  FontSize="13" Foreground="#FFD700" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="🍇" Width="30" FontSize="18" VerticalAlignment="Center" Foreground="white"/>
                        <TextBlock Text="3x" Width="22" FontSize="10" Foreground="#666" VerticalAlignment="Center"/>
                        <TextBlock Text="80"  FontSize="13" Foreground="#FFD700" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="🍑" Width="30" FontSize="18" VerticalAlignment="Center" Foreground="white"/>
                        <TextBlock Text="3x" Width="22" FontSize="10" Foreground="#666" VerticalAlignment="Center"/>
                        <TextBlock Text="40"  FontSize="13" Foreground="#FFD700" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="🍋" Width="30" FontSize="18" VerticalAlignment="Center" Foreground="white"/>
                        <TextBlock Text="3x" Width="22" FontSize="10" Foreground="#666" VerticalAlignment="Center"/>
                        <TextBlock Text="40"  FontSize="13" Foreground="#FFD700" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="🍊" Width="30" FontSize="18" VerticalAlignment="Center" Foreground="white"/>
                        <TextBlock Text="3x" Width="22" FontSize="10" Foreground="#666" VerticalAlignment="Center"/>
                        <TextBlock Text="40"  FontSize="13" Foreground="#FFD700" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="🍒" Width="30" FontSize="18" VerticalAlignment="Center" Foreground="white"/>
                        <TextBlock Text="3x" Width="22" FontSize="10" Foreground="#666" VerticalAlignment="Center"/>
                        <TextBlock Text="40"  FontSize="13" Foreground="#FFD700" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- Rács -->
            <Grid Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <!-- Üzenet sáv -->
                    <Border Background="#0d0d00" CornerRadius="7" Padding="24,7"
                            BorderBrush="#2a2a00" BorderThickness="1" Margin="0,0,0,18"
                            HorizontalAlignment="Center">
                        <TextBlock x:Name="tbUzenet" Text="TEGYE MEG A TÉTJÉT"
                                   Foreground="#FFD700" FontFamily="Consolas"
                                   FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </Border>

                    <!-- 3 oszlop kerete -->
                    <Border CornerRadius="14" Padding="8" BorderThickness="2" BorderBrush="#252520"
                            HorizontalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#141414" Offset="0"/>
                                <GradientStop Color="#0f0f0f" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#FFD700" BlurRadius="28" ShadowDepth="0" Opacity="0.15"/>
                        </Border.Effect>

                        <StackPanel Orientation="Horizontal">
                            <!-- 0 oszlop -->
                            <Border x:Name="Reel0" CornerRadius="10" Width="155" Margin="3,0"
                                    BorderBrush="#333" BorderThickness="1" ClipToBounds="True">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#1f1f1d" Offset="0"/>
                                        <GradientStop Color="#191917" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel>
                                    <Border x:Name="C00" Height="118" CornerRadius="8" Margin="4,4,4,2" BorderBrush="#222" BorderThickness="1">
                                        <TextBlock x:Name="S00" Text="🍒" FontSize="56" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border x:Name="C01" Height="118" CornerRadius="8" Margin="4,2" BorderBrush="#222" BorderThickness="1">
                                        <TextBlock x:Name="S01" Text="🍋" FontSize="56" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border x:Name="C02" Height="118" CornerRadius="8" Margin="4,2,4,4" BorderBrush="#222" BorderThickness="1">
                                        <TextBlock x:Name="S02" Text="🍊" FontSize="56" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 1 oszlop -->
                            <Border x:Name="Reel1" CornerRadius="10" Width="155" Margin="3,0"
                                    BorderBrush="#333" BorderThickness="1" ClipToBounds="True">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#1f1f1d" Offset="0"/>
                                        <GradientStop Color="#191917" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel>
                                    <Border x:Name="C10" Height="118" CornerRadius="8" Margin="4,4,4,2" BorderBrush="#222" BorderThickness="1">
                                        <TextBlock x:Name="S10" Text="🍇" FontSize="56" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border x:Name="C11" Height="118" CornerRadius="8" Margin="4,2" BorderBrush="#222" BorderThickness="1">
                                        <TextBlock x:Name="S11" Text="⭐" FontSize="56" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border x:Name="C12" Height="118" CornerRadius="8" Margin="4,2,4,4" BorderBrush="#222" BorderThickness="1">
                                        <TextBlock x:Name="S12" Text="🔔" FontSize="56" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 2 oszlop -->
                            <Border x:Name="Reel2" CornerRadius="10" Width="155" Margin="3,0"
                                    BorderBrush="#333" BorderThickness="1" ClipToBounds="True">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#1f1f1d" Offset="0"/>
                                        <GradientStop Color="#191917" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel>
                                    <Border x:Name="C20" Height="118" CornerRadius="8" Margin="4,4,4,2" BorderBrush="#222" BorderThickness="1">
                                        <TextBlock x:Name="S20" Text="🍉" FontSize="56" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border x:Name="C21" Height="118" CornerRadius="8" Margin="4,2" BorderBrush="#222" BorderThickness="1">
                                        <TextBlock x:Name="S21" Text="7" FontSize="56" Foreground="#FF3333" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border x:Name="C22" Height="118" CornerRadius="8" Margin="4,2,4,4" BorderBrush="#222" BorderThickness="1">
                                        <TextBlock x:Name="S22" Text="🍑" FontSize="56" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Nyerő vonalak jelzők -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                        <Border x:Name="V1" Margin="4,0" CornerRadius="5" Padding="10,4"
                                BorderThickness="1" Opacity="0.3">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#FFD700"/>
                            </Border.BorderBrush>
                            <Border.Background>
                                <SolidColorBrush Color="#1a1500"/>
                            </Border.Background>
                            <TextBlock Text="1" FontSize="11" Foreground="#FFD700" FontFamily="Consolas" FontWeight="Bold"/>
                        </Border>
                        <Border x:Name="V2" Margin="4,0" CornerRadius="5" Padding="10,4"
                                BorderThickness="1" Opacity="0.3">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#FFD700"/>
                            </Border.BorderBrush>
                            <Border.Background>
                                <SolidColorBrush Color="#1a1500"/>
                            </Border.Background>
                            <TextBlock Text="2" FontSize="11" Foreground="#FFD700" FontFamily="Consolas" FontWeight="Bold"/>
                        </Border>
                        <Border x:Name="V3" Margin="4,0" CornerRadius="5" Padding="10,4"
                                BorderThickness="1" Opacity="0.3">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#FFD700"/>
                            </Border.BorderBrush>
                            <Border.Background>
                                <SolidColorBrush Color="#1a1500"/>
                            </Border.Background>
                            <TextBlock Text="3" FontSize="11" Foreground="#FFD700" FontFamily="Consolas" FontWeight="Bold"/>
                        </Border>
                        <Border x:Name="V4" Margin="4,0" CornerRadius="5" Padding="10,4"
                                BorderThickness="1" Opacity="0.3">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#FFD700"/>
                            </Border.BorderBrush>
                            <Border.Background>
                                <SolidColorBrush Color="#1a1500"/>
                            </Border.Background>
                            <TextBlock Text="4" FontSize="11" Foreground="#FFD700" FontFamily="Consolas" FontWeight="Bold"/>
                        </Border>
                        <Border x:Name="V5" Margin="4,0" CornerRadius="5" Padding="10,4"
                                BorderThickness="1" Opacity="0.3">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#FFD700"/>
                            </Border.BorderBrush>
                            <Border.Background>
                                <SolidColorBrush Color="#1a1500"/>
                            </Border.Background>
                            <TextBlock Text="5" FontSize="11" Foreground="#FFD700" FontFamily="Consolas" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Jobb oldal -->
            <Border Grid.Column="2" Background="#080808" Margin="4,12,12,12" CornerRadius="12"
                    BorderBrush="#1a1a1a" BorderThickness="1">
                <StackPanel Margin="14,16,14,10" VerticalAlignment="Center">
                    <TextBlock Text="STATISZTIKA" Foreground="#FFD700" FontFamily="Consolas"
                               FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,16"/>

                    <TextBlock Text="PÖRGETÉSEK" Foreground="#444" FontFamily="Consolas" FontSize="9" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="tbPorgesek" Text="0" Foreground="#FFD700" FontFamily="Consolas"
                               FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,12"/>

                    <TextBlock Text="NYERÉSEK" Foreground="#444" FontFamily="Consolas" FontSize="9" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="tbNyeresek" Text="0" Foreground="#FFD700" FontFamily="Consolas"
                               FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,12"/>

                    <TextBlock Text="LEGJOBB NYEREMÉNY" Foreground="#444" FontFamily="Consolas"
                               FontSize="9" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    <TextBlock x:Name="tbLegjobbNyeremeny" Text="0 Ft" Foreground="#FFD700" FontFamily="Consolas"
                               FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,12"/>

                    <Rectangle Height="1" Fill="#1a1a1a" Margin="0,4,0,12"/>

                    <TextBlock Text="ÖSSZNYEREMÉNY" Foreground="#444" FontFamily="Consolas"
                               FontSize="9" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="tbOsszes" Text="0 Ft" Foreground="#FFD700" FontFamily="Consolas"
                               FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Alsó rész -->
        <Border Grid.Row="2" BorderBrush="#1a1a1a" BorderThickness="0,1,0,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#0d0d0d" Offset="0"/>
                    <GradientStop Color="#080808" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Fix vonalak -->
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Érméérték -->
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Pörgetés gomb -->
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Tét -->
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Turbo / Auto -->
                </Grid.ColumnDefinitions>

                

                <!-- Érméérték -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="ÉRMÉÉRTÉK" Foreground="#444" FontFamily="Consolas"
                               FontSize="9" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,3,0,0">
                        <Button x:Name="btnErmeCs" Style="{StaticResource KasinoGomb}"
                                Content="◀" Width="28" Height="28" Click="ErmeCs_Click"/>
                        <TextBlock x:Name="tbErme" Text="1,00 Ft" Foreground="#FFD700"
                                   FontFamily="Consolas" FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="10,0"/>
                        <Button x:Name="btnErmeN" Style="{StaticResource KasinoGomb}"
                                Content="▶" Width="28" Height="28" Click="ErmeN_Click"/>
                    </StackPanel>
                </StackPanel>

                <!-- Pörgetés -->
                <Button x:Name="btnPorget" Grid.Column="4"
                        Style="{StaticResource PörgetésGomb}"
                        VerticalAlignment="Center"
                        Click="Porget_Click"/>

                <!-- Tét -->
                <StackPanel Grid.Column="6" VerticalAlignment="Center">
                    <TextBlock Text="TÉT" Foreground="#444" FontFamily="Consolas"
                               FontSize="9" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,3,0,0">
                        <Button x:Name="btnTetCs" Style="{StaticResource KasinoGomb}"
                                Content="◀" Width="28" Height="28" Click="TetCs_Click"/>
                        <TextBlock x:Name="tbTet" Text="200" Foreground="#FFD700"
                                   FontFamily="Consolas" FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="10,0"/>
                        <Button x:Name="btnTetN" Style="{StaticResource KasinoGomb}"
                                Content="▶" Width="28" Height="28" Click="TetN_Click"/>
                    </StackPanel>
                </StackPanel>

                <!-- Turbo + Auto -->
                <StackPanel Grid.Column="8" VerticalAlignment="Center" Margin="0,0,0,0">
                    <ToggleButton x:Name="tbgTurbo" Style="{StaticResource ToggleGomb}"
                                  Content="⚡ TURBO" Margin="0,0,0,6"
                                  Checked="TurboValt" Unchecked="TurboValt"/>
                    <ToggleButton x:Name="tbgAuto" Style="{StaticResource ToggleGomb}"
                                  Content="🔄 AUTOMATIKUS"
                                  Checked="AutoValt" Unchecked="AutoValt"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>