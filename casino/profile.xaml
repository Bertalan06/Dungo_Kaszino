<Page x:Class="casino.profile"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:casino"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="1000"
      Title="profile">
    <Page.Background>
        <SolidColorBrush Color="#FF0f0f1a"/>
    </Page.Background>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- navigáció -->
        <Border Grid.Column="0" Background="#CC111122" BorderThickness="0,0,1,0">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFD700" Offset="0"/>
                    <GradientStop Color="#80000000" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <StackPanel Orientation="Vertical" Margin="0,20,0,0">

                <!-- Avatar kör -->
                <Border Width="80" Height="80" CornerRadius="40" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFD700" Offset="0"/>
                            <GradientStop Color="#B8860B" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock x:Name="avatarBetu" Text="" FontSize="36" FontWeight="Bold"
                               Foreground="#FF0f0f1a"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Felhasználónév -->
                <TextBlock x:Name="usernameTB" Text="Játékos" FontSize="16" FontWeight="SemiBold"
                           Foreground="#FFD700" HorizontalAlignment="Center" Margin="0,10,0,4"/>
                <TextBlock x:Name="egyenlegTB" Text="0 Ft" FontSize="13"
                           Foreground="#AAAACC" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <!-- Elválasztó -->
                <Rectangle Height="1" Margin="20,0,20,20">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00000000" Offset="0"/>
                            <GradientStop Color="#FFD700" Offset="0.5"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- Navigációs gombok -->
                <Button x:Name="adatok" Content="👤  Adatok" Height="48" Margin="12,4,12,4"
                        Click="adatok_Click" Tag="adatok"
                        FontSize="15" FontWeight="SemiBold" Cursor="Hand"
                        Foreground="White" BorderThickness="0">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF2a2a40" Offset="0"/>
                            <GradientStop Color="#FF1e1e30" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="8" BorderThickness="1" BorderBrush="#33FFD700">
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0,0,0"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="BorderBrush" Value="#FFD700"/>
                                    <Setter TargetName="border" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#FF3a3a55" Offset="0"/>
                                                <GradientStop Color="#FF2a2a40" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="feltoltes" Content="💰  Feltöltés" Height="48" Margin="12,4,12,4"
                        Click="feltoltes_Click"
                        FontSize="15" FontWeight="SemiBold" Cursor="Hand"
                        Foreground="White" BorderThickness="0">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF2a2a40" Offset="0"/>
                            <GradientStop Color="#FF1e1e30" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="8" BorderThickness="1" BorderBrush="#33FFD700">
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0,0,0"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="BorderBrush" Value="#FFD700"/>
                                    <Setter TargetName="border" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#FF3a3a55" Offset="0"/>
                                                <GradientStop Color="#FF2a2a40" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="kifizetes" Content="🏦  Kifizetés" Height="48" Margin="12,4,12,4"
                        Click="kifizetes_Click"
                        FontSize="15" FontWeight="SemiBold" Cursor="Hand"
                        Foreground="White" BorderThickness="0">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF2a2a40" Offset="0"/>
                            <GradientStop Color="#FF1e1e30" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="8" BorderThickness="1" BorderBrush="#33FFD700">
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0,0,0"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="BorderBrush" Value="#FFD700"/>
                                    <Setter TargetName="border" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#FF3a3a55" Offset="0"/>
                                                <GradientStop Color="#FF2a2a40" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <StackPanel VerticalAlignment="Bottom" Margin="12,40,12,20">
                    <Rectangle Height="1" Margin="0,0,0,20">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00000000" Offset="0"/>
                                <GradientStop Color="#FFD700" Offset="0.5"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Button x:Name="kijelentkezes" Content="🚪  Kijelentkezés" Height="44" Margin="0,0,0,8"
                            Click="kijelentkezes_Click"
                            FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                            Foreground="#FF6666" BorderThickness="0">
                        <Button.Background>
                            <SolidColorBrush Color="#33FF0000"/>
                        </Button.Background>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}"
                                        CornerRadius="8" BorderThickness="1" BorderBrush="#55FF0000">
                                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#55FF0000"/>
                                        <Setter TargetName="border" Property="BorderBrush" Value="#FFFF0000"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="vissza" Content="◄  Vissza" Height="44"
                            Click="vissza_Click"
                            FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                            Foreground="#AAAACC" BorderThickness="0">
                        <Button.Background>
                            <SolidColorBrush Color="#22FFFFFF"/>
                        </Button.Background>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}"
                                        CornerRadius="8" BorderThickness="1" BorderBrush="#33FFFFFF">
                                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#33FFFFFF"/>
                                        <Setter TargetName="border" Property="BorderBrush" Value="#AAAACC"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- tartalom -->
        <Grid Grid.Column="1" Margin="30,30,30,30">

            <!-- adatok panel -->
            <ScrollViewer x:Name="adatokPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Felhasználói adatok" FontSize="24" FontWeight="Bold" Foreground="#FFD700" Margin="0,0,0,24"/>

                    <!-- kártyák -->
                    <Border CornerRadius="12" Padding="24" Margin="0,0,0,16">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF1a1a2e" Offset="0"/>
                                <GradientStop Color="#FF16213e" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FFD700" Offset="0"/>
                                <GradientStop Color="#33FFD700" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.BorderThickness>1</Border.BorderThickness>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Felhasználónév -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,20">
                                <TextBlock Text="TELJES NÉV" FontSize="11" FontWeight="Bold"  Foreground="#888899" Margin="0,0,0,6"/>
                                <Border CornerRadius="6" Padding="12,10" Background="#22FFFFFF">
                                    <TextBlock x:Name="adatFullNameTB" Text="—" FontSize="15" Foreground="White"/>
                                </Border>
                            </StackPanel>

                            <!-- E-mail -->
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,20">
                                <TextBlock Text="E-MAIL" FontSize="11" FontWeight="Bold" Foreground="#888899" Margin="0,0,0,6"/>
                                <Border CornerRadius="6" Padding="12,10" Background="#22FFFFFF">
                                    <TextBlock x:Name="adatEmailTB" Text="—" FontSize="15" Foreground="White"/>
                                </Border>
                            </StackPanel>

                            <!-- Születési dátum -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,20">
                                <TextBlock Text="SZÜLETÉSI DÁTUM" FontSize="11" FontWeight="Bold"
                                           Foreground="#888899" Margin="0,0,0,6"/>
                                <Border CornerRadius="6" Padding="12,10" Background="#22FFFFFF">
                                    <TextBlock x:Name="adatSzulTB" Text="—" FontSize="15" Foreground="White"/>
                                </Border>
                            </StackPanel>

                            <!-- Telefonszám -->
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,16,20">
                                <TextBlock Text="TELEFONSZÁM" FontSize="11" FontWeight="Bold" Foreground="#888899" Margin="0,0,0,6"/>
                                <Border CornerRadius="6" Padding="12,10" Background="#22FFFFFF">
                                    <TextBlock x:Name="adatTelefonTB" Text="—" FontSize="15" Foreground="White"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- FELTÖLTÉS panel -->
            <ScrollViewer x:Name="feltoltesPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Egyenleg feltöltése" FontSize="24" FontWeight="Bold"
                               Foreground="#FFD700" Margin="0,0,0,24"/>

                    <Border CornerRadius="12" Padding="24" Margin="0,0,0,16">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF1a1a2e" Offset="0"/>
                                <GradientStop Color="#FF16213e" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FFD700" Offset="0"/>
                                <GradientStop Color="#33FFD700" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.BorderThickness>1</Border.BorderThickness>
                        <StackPanel>
                            <!-- Összeg kiválasztás -->
                            <TextBlock Text="FELTÖLTÉSI ÖSSZEG" FontSize="11" FontWeight="Bold"
                                       Foreground="#888899" Margin="0,0,0,12"/>
                            <WrapPanel Margin="0,0,0,20">
                                <Button x:Name="felt1000" Content="1 000 Ft" Width="110" Height="44" Margin="0,0,10,10"
                                        Click="FeltoltesOsszeg_Click" Tag="1000"
                                        FontSize="14" FontWeight="SemiBold" Foreground="White" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="b" CornerRadius="8" BorderThickness="1" BorderBrush="#33FFD700" Background="#22FFD700">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="b" Property="BorderBrush" Value="#FFD700"/>
                                                    <Setter TargetName="b" Property="Background" Value="#44FFD700"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button x:Name="felt5000" Content="5 000 Ft" Width="110" Height="44" Margin="0,0,10,10"
                                        Click="FeltoltesOsszeg_Click" Tag="5000"
                                        FontSize="14" FontWeight="SemiBold" Foreground="White" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="b" CornerRadius="8" BorderThickness="1" BorderBrush="#33FFD700" Background="#22FFD700">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="b" Property="BorderBrush" Value="#FFD700"/>
                                                    <Setter TargetName="b" Property="Background" Value="#44FFD700"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button x:Name="felt10000" Content="10 000 Ft" Width="110" Height="44" Margin="0,0,10,10"
                                        Click="FeltoltesOsszeg_Click" Tag="10000"
                                        FontSize="14" FontWeight="SemiBold" Foreground="White" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="b" CornerRadius="8" BorderThickness="1" BorderBrush="#33FFD700" Background="#22FFD700">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="b" Property="BorderBrush" Value="#FFD700"/>
                                                    <Setter TargetName="b" Property="Background" Value="#44FFD700"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button x:Name="felt50000" Content="50 000 Ft" Width="110" Height="44" Margin="0,0,10,10"
                                        Click="FeltoltesOsszeg_Click" Tag="50000"
                                        FontSize="14" FontWeight="SemiBold" Foreground="White" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="b" CornerRadius="8" BorderThickness="1" BorderBrush="#33FFD700" Background="#22FFD700">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="b" Property="BorderBrush" Value="#FFD700"/>
                                                    <Setter TargetName="b" Property="Background" Value="#44FFD700"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </WrapPanel>

                            <!-- Egyéni összeg -->
                            <TextBlock Text="EGYÉNI ÖSSZEG" FontSize="11" FontWeight="Bold"
                                       Foreground="#888899" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="8,0,0,8" BorderThickness="1,1,0,1" BorderBrush="#33FFD700" Background="#22FFFFFF" Margin="0,0,0,0">
                                    <TextBox x:Name="feltoltesOsszegTB" Background="Transparent" Foreground="White"
                                             FontSize="16" BorderThickness="0" Padding="12,10"
                                             CaretBrush="White" Text="0"/>
                                </Border>
                                <Border Grid.Column="0" IsHitTestVisible="False" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="Ft" Foreground="#888899" FontSize="14"/>
                                </Border>
                                <Button Grid.Column="1" x:Name="feltoltesGomb" Content="Feltöltés" Height="44"
                                        Click="FeltoltesVegrehajt_Click" Cursor="Hand"
                                        FontSize="14" FontWeight="Bold" Foreground="#FF0f0f1a">
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#FFD700" Offset="0"/>
                                            <GradientStop Color="#B8860B" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="b" CornerRadius="0,8,8,0" Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="b" Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <!-- Fizetési mód -->
                            <TextBlock Text="FIZETÉSI MÓD" FontSize="11" FontWeight="Bold"
                                       Foreground="#888899" Margin="0,0,0,12"/>
                            <WrapPanel Margin="0,0,0,8">
                                <RadioButton x:Name="rbKartya" Content="💳  Bankkártya" GroupName="fizmod"
                                             Foreground="White" FontSize="14" Margin="0,0,20,8"
                                             IsChecked="True">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="b" CornerRadius="8" Padding="16,10" BorderThickness="1" BorderBrush="#33FFD700" Background="#22FFFFFF">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="b" Property="BorderBrush" Value="#FFD700"/>
                                                    <Setter TargetName="b" Property="Background" Value="#33FFD700"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                                <RadioButton x:Name="rbUtalas" Content="🏦  Banki átutalás" GroupName="fizmod"
                                             Foreground="White" FontSize="14" Margin="0,0,20,8">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="b" CornerRadius="8" Padding="16,10" BorderThickness="1" BorderBrush="#33FFD700" Background="#22FFFFFF">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="b" Property="BorderBrush" Value="#FFD700"/>
                                                    <Setter TargetName="b" Property="Background" Value="#33FFD700"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- KIFIZETÉS panel -->
            <ScrollViewer x:Name="kifizetesPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Egyenleg kifizetése" FontSize="24" FontWeight="Bold"
                               Foreground="#FFD700" Margin="0,0,0,24"/>

                    <Border CornerRadius="12" Padding="24" Margin="0,0,0,16">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF1a1a2e" Offset="0"/>
                                <GradientStop Color="#FF16213e" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FFD700" Offset="0"/>
                                <GradientStop Color="#33FFD700" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.BorderThickness>1</Border.BorderThickness>
                        <StackPanel>
                            <!-- Elérhető egyenleg -->
                            <Border CornerRadius="8" Padding="16" Background="#22FFD700" Margin="0,0,0,20">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Elérhető egyenleg: " FontSize="15" Foreground="#AAAACC" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="kifizetesEgyenlegTB" Text="0 Ft" FontSize="18" FontWeight="Bold" Foreground="#FFD700" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Összeg -->
                            <TextBlock Text="KIFIZETÉSI ÖSSZEG" FontSize="11" FontWeight="Bold"
                                       Foreground="#888899" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="8,0,0,8" BorderThickness="1,1,0,1" BorderBrush="#33FFD700" Background="#22FFFFFF">
                                    <TextBox x:Name="kifizetesOsszegTB" Background="Transparent" Foreground="White"
                                             FontSize="16" BorderThickness="0" Padding="12,10"
                                             CaretBrush="White" Text="0"/>
                                </Border>
                                <Border Grid.Column="0" IsHitTestVisible="False" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="Ft" Foreground="#888899" FontSize="14"/>
                                </Border>
                                <Button Grid.Column="1" Content="Kifizetés" Height="44"
                                        Click="KifizetesVegrehajt_Click" Cursor="Hand"
                                        FontSize="14" FontWeight="Bold" Foreground="White">
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#FF4caf50" Offset="0"/>
                                            <GradientStop Color="#FF388e3c" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="b" CornerRadius="0,8,8,0" Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="b" Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <!-- Kifizetési mód -->
                            <TextBlock Text="KIFIZETÉSI MÓD" FontSize="11" FontWeight="Bold"
                                       Foreground="#888899" Margin="0,0,0,12"/>
                            <WrapPanel Margin="0,0,0,20">
                                <RadioButton x:Name="rbKifKartya" Content="💳  Bankkártya" GroupName="kifmod"
                                             Foreground="White" FontSize="14" Margin="0,0,20,8"
                                             IsChecked="True">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="b" CornerRadius="8" Padding="16,10" BorderThickness="1" BorderBrush="#33FFD700" Background="#22FFFFFF">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="b" Property="BorderBrush" Value="#FFD700"/>
                                                    <Setter TargetName="b" Property="Background" Value="#33FFD700"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                                <RadioButton x:Name="rbKifUtalas" Content="🏦  Banki átutalás" GroupName="kifmod"
                                             Foreground="White" FontSize="14" Margin="0,0,20,8">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="b" CornerRadius="8" Padding="16,10" BorderThickness="1" BorderBrush="#33FFD700" Background="#22FFFFFF">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="b" Property="BorderBrush" Value="#FFD700"/>
                                                    <Setter TargetName="b" Property="Background" Value="#33FFD700"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                            </WrapPanel>

                            <!-- kártyaszám -->
                            <TextBlock Text="BANKSZÁMLASZÁM / KÁRTYASZÁM" FontSize="11" FontWeight="Bold"
                                       Foreground="#888899" Margin="0,0,0,8"/>
                            <Border CornerRadius="8" BorderThickness="1" BorderBrush="#33FFD700" Background="#22FFFFFF" Margin="0,0,0,4">
                                <TextBox x:Name="kifizetesIbanTB" Background="Transparent" Foreground="White"
                                         FontSize="15" BorderThickness="0" Padding="12,10"
                                         CaretBrush="White"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
